# Optional server-side OpenAI key for live GPT-5.6 tutoring and diagnostics.
# Never put an API key in a VITE_* variable: Vite exposes those values to browsers.
OPENAI_API_KEY=

# Public feature switch only. Set to true on a hosted build after configuring
# OPENAI_API_KEY in that host's server environment. Defaults to local fallback.
VITE_ENABLE_LIVE_TUTOR=false
